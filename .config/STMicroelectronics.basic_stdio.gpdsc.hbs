<package xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" schemaVersion="1.7.55" xsi:noNamespaceSchemaLocation="PACK.xsd" xmlns:stm32="https://developer.st.com/schemas/stm32cube/1.0.0" xsi:schemaLocation="https://developer.st.com/schemas/stm32cube/1.0.0 stm32cube.xsd" Dvendor="STMicroelectronics:13" Dname="STM32*">
  {{!--Dedicated Helper that provides the PDSC PackVendor--}}
  <vendor>{{@root.pdscAPI.getPackVendor}}</vendor>
  {{!--Dedicated Helper that provides the PDSC PackName--}}
  <name>{{@root.pdscAPI.getPackName}}</name>
  {{!--URL Tag, kept here since its required for valid schema parsing--}}
  <url>{{@root.pdscAPI.getPackURL}}</url>
  {{!--Release Section to update manually in case of new updated--}}
  <releases>
    <release version="2.0.0" date="2026-01-16">
      - First GPDSC template Model Release
    </release>
  </releases>
  <conditions>
    {{assign "conditions" (@root.pdscAPI.getAllPDSCConditionsWithFilters exclude="Basic stdio Config")}}
    {{{@root.conditions}}}
    {{!-- Excluded conditions by Id above could optionally be handled dynamically in this section--}}
    {{!-- #Start Dynamic condition handling section# --}}
    <condition id="Basic stdio Config">
      <description>selection of io interface is required to use the component</description>
      <require Cclass="Utility" Cgroup="Basic stdio" Csub="Core"/>
      {{#if (eq @root.basic_stdio_cxt.resourcesAllocation.output_interface "ITM")}}
      <require Cclass="Utility" Cgroup="Basic stdio" Csub="itf_io" Cvariant="ITM"/>
      {{else}}
        {{#if (eq @root.basic_stdio_cxt.resourcesAllocation.output_interface "CUSTOM")}}
      <require Cclass="Utility" Cgroup="Basic stdio" Csub="itf_io" Cvariant="Template"/>
        {{else}}
          {{#if (eq @root.basic_stdio_cxt.resourcesAllocation.output_interface "UART")}}
      <require Cclass="Utility" Cgroup="Basic stdio" Csub="itf_io" Cvariant="UART"/>
          {{/if}}
        {{/if}}
      {{/if}}
    </condition>
    {{!-- This is an optional section, if you do not want to handle conditions dynamically, you can bypass this --}}
    {{!-- #End Dynamic condition handling section# --}}
    </conditions>
    {{!-- This section will list all selected components with their descriptions, along with their generated files--}}
    <components>
      {{#each components}}
      <component {{{generatorId}}} {{{Cclass}}} {{{Cgroup}}} {{{Csub}}} {{{Cvariant}}} {{{Cversion}}} {{{condition}}}>
        <description>{{description}}</description>
        <files>
          {{#each files_array}}
          <file category="{{category}}" name="{{gen_file}}" />
          {{/each}}
        </files>
      </component>
      {{/each}}
    </components>
    </package>
