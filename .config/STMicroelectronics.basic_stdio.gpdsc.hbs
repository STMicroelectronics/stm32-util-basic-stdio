{{assign 'basic_stdioFilter' (JSONparse '{"cgroup": "STM32CubeMX2 Config", "csub": "Basic stdio"}')~}}
{{assign 'basic_stdio_context' (@root.SWConfigurationAPI.getInstancesConfiguration @root.basic_stdioFilter)~}}
{{assign 'basic_stdio_cxt' @root.basic_stdio_context.[0].settings.parameters~}}
{{log "basic_stdio Config template basic_stdio_cxt:" (toJSON @root.basic_stdio_cxt)~}}
<?xml version="1.0" encoding="UTF-8"?>
<!-- ******************************************************************************
 * File Name   : {{@root.pdscAPI.getGPDSCFileName}}
 * Description : Generator PDSC File generated by CodeGen
  ******************************************************************************
  * @attention
